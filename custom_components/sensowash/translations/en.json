{
  "config": {
    "step": {
      "user": {
        "title": "Set up SensoWash",
        "description": "Found {found} SensoWash device(s) nearby. Select one below, or enter a Bluetooth address manually.",
        "data": {
          "address": "Device"
        }
      },
      "bluetooth_confirm": {
        "title": "Found SensoWash",
        "description": "Do you want to set up **{name}** ({address})?"
      },
      "pairing": {
        "title": "Pair your SensoWash",
        "description": "**{name}** uses the serial Bluetooth protocol and needs to be paired before it can be controlled.\n\n### How to put your toilet in pairing mode\n\n1. Make sure the toilet is powered on\n2. Locate the **Bluetooth pairing button** — on most models this is a small button on the **side panel** of the toilet unit, marked with the Bluetooth symbol (℃). On remote-control models it may be on the remote.\n3. **Press and hold the button for 3 seconds** until the indicator flashes\n4. The toilet will respond to Home Assistant automatically\n\nYou have **{timeout} seconds** from when this screen appeared. If the timer runs out, you can try again on the next screen."
      },
      "pairing_confirm": {
        "title": "Pairing successful!",
        "description": "**{name}** has been paired. The pairing key has been saved — you won't need to do this again.\n\nClick **Submit** to finish setup."
      },
      "pairing_failed": {
        "title": "Pairing timed out",
        "description": "No response was received from **{name}** within {timeout} seconds. Make sure you pressed the Bluetooth button on the toilet during the countdown.\n\nWould you like to try again?",
        "data": {
          "retry": "Try again"
        }
      }
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "already_in_progress": "[%key:common::config_flow::abort::already_in_progress%]",
      "no_devices_found": "No SensoWash devices found nearby.",
      "pairing_failed": "Pairing was cancelled."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "SensoWash options",
        "description": "Configure options for {address}.\n\nThe **pairing key** is only needed for older serial-protocol models. Leave blank for modern GATT devices.",
        "data": {
          "pairing_key": "Pairing key (hex, e.g. 01:23:45:67)"
        }
      }
    },
    "error": {
      "invalid_pairing_key": "Pairing key must be 4 hex bytes (e.g. 01:23:45:67 or 01234567)."
    }
  },
